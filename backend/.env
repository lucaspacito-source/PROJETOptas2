# Porta do servidor (opcional para o backend)
PORT=3000

# Ambiente do Node (opcional)
NODE_ENV=development

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://postgres:senha@localhost:5432/musify?schema=public

# Secrets do seu app (não comitar)
BETTER_AUTH_SECRET=auth-secret-key-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Outras chaves externas, se tiver
# API_GITHUB="ghp_xxxxxxxxxxxx"
# API_TWILIO="xxxxxxxxxxxxx"